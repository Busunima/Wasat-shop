# Пример окружения. Скопируйте в .env (не коммитится) и заполните для локальной разработки.
# В production значения приходят из Google Secret Manager / переменных Cloud Run.
# Секреты БЕЗ fallback в production (ТЗ §13).

NODE_ENV=development
PORT=8080

# Firebase
GOOGLE_CLOUD_PROJECT=wasat-shop-dev
# Локально против эмуляторов (firebase/firebase.json):
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# В проде путь к serviceAccount задаётся через Secret Manager, не через файл в репо.

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_BILLING_WEBHOOK_SECRET=whsec_xxx

# Algolia
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=

# Cron
CRON_SECRET=change_me_in_prod

# SMTP (Nodemailer)
SMTP_URL=smtp://user:pass@localhost:1025
