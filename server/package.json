{
  "name": "@wasat/server",
  "version": "0.1.0",
  "private": true,
  "description": "Express + TypeScript backend for Wasat Shop (ТЗ §2, §9)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "node --test --import tsx \"test/unit/**/*.test.ts\"",
    "test:integration": "firebase emulators:exec --only firestore,auth --project demo-wasat --config ../firebase/firebase.json \"node --test --import tsx 'test/integration/**/*.test.ts'\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "express": "^4.21.2",
    "firebase-admin": "^13.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
