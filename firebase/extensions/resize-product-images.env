# Параметры расширения Storage Resize Images (FR-A02: авто-миниатюры фото товаров).
# Деплой: firebase deploy --only extensions --project wasat-21a20
# Соглашение имён: к файлу добавляется суффикс размера — image.jpg -> image_200x200.webp
# (см. docs/decisions.md и android/.../ImageUrls.kt).

IMG_BUCKET=wasat-21a20.firebasestorage.app
IMG_SIZES=200x200,800x800
IMAGE_TYPE=webp
INCLUDE_PATH_LIST=/stores/*/products/**
DELETE_ORIGINAL_FILE=false
MAKE_PUBLIC=false
IS_ANIMATED=false
FUNCTION_MEMORY=1024
DO_BACKFILL=false
