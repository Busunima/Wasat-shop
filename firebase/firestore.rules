rules_version = '2';

// Каркас правил из ТЗ §4.3. Изоляция данных по storeId.
//
// ВАЖНО: заказы, аналитика и списание стока выполняются СЕРВЕРОМ через Admin SDK —
// правила игнорируются Admin SDK и защищают только прямой клиентский доступ.
// Поэтому для клиента запись в orders/analytics/inventory здесь не разрешается.

service cloud.firestore {
  match /databases/{db}/documents {

    function isOwner(s) {
      return request.auth != null &&
        get(/databases/$(db)/documents/stores/$(s)).data.ownerUid == request.auth.uid;
    }

    function isStaff(s) {
      return request.auth != null &&
        exists(/databases/$(db)/documents/stores/$(s)/staff/$(request.auth.uid));
    }

    match /stores/{storeId} {
      allow read: if resource.data.isPublic == true || isOwner(storeId) || isStaff(storeId);
      allow write: if isOwner(storeId);

      match /products/{pid} {
        allow read: if true;
        allow write: if isOwner(storeId) || isStaff(storeId);
      }

      match /categories/{cid} {
        allow read: if true;
        allow write: if isOwner(storeId);
      }

      match /orders/{oid} {
        // Чтение: владелец, сотрудник или сам покупатель.
        // Запись — только сервер (Admin SDK), клиенту запрещена.
        allow read: if isOwner(storeId) || isStaff(storeId)
                       || resource.data.customerUid == request.auth.uid;
        allow write: if false;
      }

      match /analytics/{d} {
        allow read: if isOwner(storeId);
        allow write: if false;
      }

      // Профиль покупателя в магазине: корзина (FR-B04 sync), вишлист, адреса.
      // Пишет только сам покупатель; владелец/сотрудник читают (кабинет, ПДн §13).
      match /customers/{uid} {
        allow read: if request.auth != null &&
                       (request.auth.uid == uid || isOwner(storeId) || isStaff(storeId));
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Отзывы (FR-B08): публичный контент карточки; пишет только сервер
      // (право на отзыв проверяется по заказу в Admin SDK).
      match /reviews/{rid} {
        allow read: if true;
        allow write: if false;
      }

      // Возвраты (FR-A11/B09): чтение — владелец/сотрудник или сам покупатель;
      // переходы статусов и Stripe Refund — только сервер.
      match /returns/{ret} {
        allow read: if isOwner(storeId) || isStaff(storeId)
                       || resource.data.customerUid == request.auth.uid;
        allow write: if false;
      }

      // Серверные коллекции (Admin SDK) — прямой клиентский доступ запрещён:
      // промокоды (превью только через REST), членство сотрудников, FCM-токены
      // устройств (ПДн), журналы остатков/аудита, агрегаты выручки.
      match /promocodes/{code} { allow read, write: if false; }
      match /staff/{uid}       { allow read, write: if false; }
      match /fcmTokens/{uid}   { allow read, write: if false; }
      match /inventoryLog/{id} { allow read, write: if false; }
      match /auditLog/{id}     { allow read, write: if false; }
    }

    // Публичный обратный индекс slug -> storeId (резолв витрины по ссылке/QR).
    match /slugs/{slug} {
      allow read: if true;
      allow write: if false; // пишет сервер
    }

    // Список магазинов пользователя (владелец/сотрудник).
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // пишет сервер
    }
  }
}
