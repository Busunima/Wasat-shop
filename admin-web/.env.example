# Конфиг веб-приложения суперадмина. Скопируйте в .env (не коммитится).
# Значения Firebase Web App берутся из консоли (Project settings → Web app).
# Без них приложение собирается, но показывает «не сконфигурировано» (как Android).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# База серверного API
VITE_API_BASE_URL=http://localhost:8080/
